{
  "name": "fluncle",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@ai-sdk/react": "4.0.20",
      "@base-ui/react": "~1.6.0",
      "@libsql/client": "~0.17.4",
      "@openrouter/ai-sdk-provider": "~3.0.0",
      "@orpc/client": "1.14.7",
      "@orpc/contract": "1.14.7",
      "@orpc/openapi": "1.14.7",
      "@orpc/openapi-client": "1.14.7",
      "@orpc/server": "1.14.7",
      "@orpc/tanstack-query": "1.14.7",
      "@orpc/zod": "1.14.7",
      "@phosphor-icons/react": "~2.1.10",
      "@remotion/bundler": "~4.0.487",
      "@remotion/captions": "~4.0.487",
      "@remotion/cli": "~4.0.487",
      "@remotion/fonts": "~4.0.487",
      "@remotion/renderer": "~4.0.487",
      "@tanstack/react-query": "~5.101.2",
      "@types/bun": "~1.3.14",
      "@types/node": "~26.1.1",
      "@types/react": "~19.2.17",
      "@types/react-dom": "~19.2.3",
      "ai": "~7.0.19",
      "class-variance-authority": "~0.7.1",
      "cmdk": "~1.1.1",
      "cnfast": "~0.0.8",
      "commander": "~15.0.0",
      "dotenv": "~17.4.2",
      "drizzle-kit": "~0.31.10",
      "drizzle-orm": "~0.45.2",
      "react-dom": "~19.2.7",
      "remotion": "~4.0.487",
      "sonner": "~2.0.7",
      "typescript": "~7.0.2",
      "zod": "4.4.3"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run test:scripts && bun run build",
    "check:fix": "bun run lint:fix && bun run format",
    "deploy:gate": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run test:scripts",
    "dev": "turbo run dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --ignore-path .prettierignore --type-aware --deny-warnings",
    "lint:fix": "oxlint --fix --ignore-path .prettierignore --type-aware --deny-warnings",
    "skills:install": "bun run scripts/install-skills.ts",
    "stories:build": "bun scripts/build-user-story-matrix.ts",
    "social:preview": "bun run --cwd packages/video social:preview",
    "test": "turbo run test",
    "test:scripts": "bun test --cwd docs/agents/hermes/scripts && bun test --cwd packages/skills/fluncle-track-enrichment/scripts",
    "prepare": "command -v husky > /dev/null 2>&1 && husky || true",
    "typecheck": "turbo run typecheck",
    "doctor": "npx react-doctor@latest"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "husky": "~9.1.7",
    "lint-staged": "~17.0.8",
    "oxfmt": "~0.58.0",
    "oxlint": "~1.73.0",
    "oxlint-tsgolint": "~0.24.0",
    "react-doctor": "~0.5.8",
    "turbo": "~2.10.4",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*": [
      "oxlint --fix --ignore-path .prettierignore --no-error-on-unmatched-pattern",
      "oxfmt --write --ignore-path .prettierignore --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "bun@1.3.14",
  "patchedDependencies": {
    "@remotion/bundler@4.0.487": "patches/@remotion%2Fbundler@4.0.487.patch"
  },
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ]
}
