{
  "name": "fluncle",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@libsql/client": "~0.15.15",
      "@types/bun": "~1.3.14",
      "@types/node": "~22.19.20",
      "commander": "~14.0.3",
      "dotenv": "~16.6.1",
      "drizzle-kit": "~0.31.10",
      "drizzle-orm": "~0.45.2",
      "typescript": "~5.9.3"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run build",
    "check:fix": "bun run lint:fix && bun run format",
    "dev": "turbo run dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --ignore-path .prettierignore --type-aware",
    "lint:fix": "oxlint --fix --ignore-path .prettierignore --type-aware",
    "postinstall": "command -v husky > /dev/null 2>&1 && husky || true",
    "social:preview": "bun run --cwd packages/video social:preview",
    "prepare": "command -v husky > /dev/null 2>&1 && husky || true",
    "typecheck": "turbo run typecheck",
    "doctor": "npx react-doctor@latest"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "husky": "~9.1.7",
    "lint-staged": "~17.0.7",
    "oxfmt": "~0.48.0",
    "oxlint": "~1.69.0",
    "oxlint-tsgolint": "~0.22.1",
    "react-doctor": "^0.5.1",
    "turbo": "~2.9.16",
    "typescript": "catalog:"
  },
  "overrides": {
    "@getspinup/constants": "0.4.0"
  },
  "lint-staged": {
    "*": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ]
}
