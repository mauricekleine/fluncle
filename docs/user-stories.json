{
  "meta": {
    "title": "Fluncle user stories × public surfaces",
    "description": "Every public-facing user story, split by register (lore vs catalogue), grouped by entity, with per-surface support. Cells are FACTS about shipped code, each backed by an evidence pointer (route, op id, tool, or command). 'planned' marks operator-ratified intent only — it is a direction flag, not a spec (docs/planning rules apply). Regenerate the HTML/CSV with `bun run stories:build`.",
    "updated": "2026-07-21",
    "states": {
      "yes": "shipped and reachable",
      "partial": "shipped with a real limitation (see note)",
      "no": "not supported today (the gap list)",
      "planned": "operator-ratified intent, not yet built",
      "n/a": "deliberately not applicable to this surface"
    },
    "cellDefault": "A surface omitted from a story's support map means state \"no\"."
  },
