[Unit]
Description=fluncle-artist-follow — rave-02 host trigger for the artist auto-follow sweep (migrated off the Hermes gateway cron runner)
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/artist-follow-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged
# hermes user. The .sh/.ts pair is BAKED at /opt/hermes-scripts/ (Unit A — auto-updates from
# main via pin-watch); this host unit only TRIGGERS it, and the sweep self-writes its /status
# marker (cron-output.sh) so the prober stays honest.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/artist-follow-sweep.sh
# A pure Worker-trigger (the box holds no YouTube token); one bounded batch per tick, the
# Worker performs the YouTube subscriptions.insert then stamps followed_at. Zero box tokens.
TimeoutStartSec=300
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
