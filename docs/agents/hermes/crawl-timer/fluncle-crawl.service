[Unit]
Description=fluncle-crawl — rave-02 host trigger for the catalogue crawler's bounded pass
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/crawl-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service
# If this unit dies before writing its own /status marker (OOM, missing binary, a crash
# before the sweep catch runs), the healthcheck prober never sees a failure. This catch-all
# posts a minimal Discord alert; %n is this unit's full name.
OnFailure=fluncle-sweep-failure@%n.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the
# unprivileged hermes user. The .sh/.ts pair is BAKED at /opt/hermes-scripts/ (auto-updates
# from main via pin-watch); this host unit only TRIGGERS it, and the sweep self-writes its
# /status marker (cron-output.sh). NO new secret: `crawl_catalogue` is AGENT tier, so the
# box's existing agent-scoped token drives it.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/crawl-sweep.sh
# A PURE trigger — zero LLM tokens. One pass is ~10 MusicBrainz calls paced at ~1 req/s in
# the Worker (≈12–38s normal), plus headroom for a Retry-After'd 503. The old 120s ceiling
# false-killed a tick that merely overlapped a pin-watch docker image build (~4 min of heavy
# CPU contention on this 4-vCPU box); 600s clears that window with room to spare. It equals
# the 10-min cadence: systemd never starts a new tick while one is active, so an over-long
# pass just skips the next trigger and self-heals — it is a backstop, never the normal path.
TimeoutStartSec=600
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
