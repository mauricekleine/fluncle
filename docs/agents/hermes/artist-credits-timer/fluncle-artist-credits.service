[Unit]
Description=fluncle-artist-credits — rave-02 host trigger for the MB-credit sweep's bounded batch
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/artist-credits-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service
# If this unit dies before writing its own /status marker (OOM, missing binary, a crash
# before the sweep catch runs), the healthcheck prober never sees a failure. This catch-all
# posts a minimal Discord alert; %n is this unit's full name.
OnFailure=fluncle-sweep-failure@%n.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged hermes
# user. The .sh/.ts pair is BAKED at /opt/hermes-scripts/ (auto-updates from main via pin-watch);
# this host unit only TRIGGERS it, and the sweep self-writes its /status marker (cron-output.sh).
# NO new secret: `backfill_artist_credits` is AGENT tier, so the box's existing agent-scoped token
# drives it.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/artist-credits-sweep.sh
# A PURE trigger — zero LLM tokens. One batch is up to 40 MusicBrainz recording lookups paced at
# ~1 req/s in the Worker; the vendor circuit breaker stops the pass on a throttle and a 60s response
# budget pauses it under cross-sweep contention (the CLI then issues at most one more request with a
# fresh budget), so a tick is normally ~under a minute and ~2 minutes at worst. The 240s ceiling
# clears that with headroom and still sits under the 5-min cadence (systemd skips an overlapping
# trigger rather than double-firing this oneshot).
TimeoutStartSec=240
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
