[Unit]
Description=fluncle-newsletter — rave-02 host trigger for the weekly newsletter draft sweep (migrated off the Hermes gateway cron runner)
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/newsletter-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged
# hermes user (hermes owns the 0600 secrets file the .sh sources — CLAUDE_CODE_OAUTH_TOKEN for
# the one `claude -p` authoring call). The .sh/.ts pair is BAKED at /opt/hermes-scripts/ (Unit
# A — auto-updates from main via pin-watch); this host unit only TRIGGERS it, and the sweep
# self-writes its /status marker (cron-output.sh) so the prober stays honest.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/newsletter-sweep.sh
# HYBRID: one `claude -p` authoring call drafts the edition, then it PERSISTS a Resend Broadcast
# draft (the send is a SEPARATE operator-gated command). Give the authoring step headroom.
TimeoutStartSec=900
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
