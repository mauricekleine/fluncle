# Gateway env-file template (op inject -i this -o /etc/hermes.env). Placeholder refs —
# the real template on the box uses the concrete vault; see the "Fluncle — Ops Runbook" note.
OPENROUTER_API_KEY={{ op://<automations-vault>/OPENROUTER_API_KEY/credential }}
DISCORD_BOT_TOKEN={{ op://<automations-vault>/DISCORD_BOT_TOKEN/credential }}
DISCORD_ALLOWED_USERS={{ op://<automations-vault>/DISCORD_ALLOWED_USERS/credential }}
DISCORD_ALERT_WEBHOOK={{ op://<automations-vault>/DISCORD_ALERT_WEBHOOK/credential }}
FLUNCLE_API_TOKEN={{ op://<automations-vault>/FLUNCLE_API_TOKEN/credential }}
