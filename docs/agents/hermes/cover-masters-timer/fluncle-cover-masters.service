[Unit]
Description=fluncle-cover-masters — rave-02 host trigger for the owned-cover-master resolve sweep's bounded batch
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/cover-masters-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service
# If this unit dies before writing its own /status marker (OOM, missing binary, a crash
# before the sweep catch runs), the healthcheck prober never sees a failure. This catch-all
# posts a minimal Discord alert; %n is this unit's full name.
OnFailure=fluncle-sweep-failure@%n.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged hermes
# user. The .sh/.ts pair is BAKED at /opt/hermes-scripts/ (auto-updates from main via pin-watch);
# this host unit only TRIGGERS it, and the sweep self-writes its /status marker (cron-output.sh).
# NO new secret: `backfill_cover_masters` is AGENT tier, so the box's existing agent-scoped token
# drives it.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/cover-masters-sweep.sh
# A PURE trigger — zero LLM tokens. One batch is a couple dozen single image GETs per kind; well
# under a minute. 120s is generous.
TimeoutStartSec=120
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
