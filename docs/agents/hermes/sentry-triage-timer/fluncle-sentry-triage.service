[Unit]
Description=fluncle-sentry-triage — nightly Sentry triage (opens a fix PR per straightforward issue; files the rest)
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/sentry-triage-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service
# If this unit dies before writing its own /status marker (OOM, missing binary, a crash before the
# sweep catch runs), the healthcheck prober never sees a failure. This catch-all posts a minimal
# Discord alert; %n is this unit's full name.
OnFailure=fluncle-sweep-failure@%n.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged hermes
# user. The .sh + .ts + prompt are BAKED at /opt/hermes-scripts (Unit A — auto-updates from main via
# pin-watch); this host unit only TRIGGERS the sweep, which self-writes its /status marker (cron-output.sh).
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/sentry-triage-sweep.sh
# A full agentic `claude -p` triage — freshen an isolated checkout, bun install, locate each bug →
# fix → run scoped checks → commit → push → open a PR — needs a long budget, like the audit sweep
# (not the 300s Worker-trigger sweeps). One hour is a generous ceiling; a healthy night is far shorter.
TimeoutStartSec=3600
# Modest hardening for a root docker-driving oneshot (matches the sweep units).
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
