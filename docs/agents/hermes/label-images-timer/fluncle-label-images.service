[Unit]
Description=fluncle-label-images — rave-02 host trigger for the label-image resolve sweep's bounded batch
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/label-images-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged hermes
# user. The .sh/.ts pair is BAKED at /opt/hermes-scripts/ (auto-updates from main via pin-watch);
# this host unit only TRIGGERS it, and the sweep self-writes its /status marker (cron-output.sh).
# NO new secret: `backfill_label_images` is AGENT tier, so the box's existing agent-scoped token
# drives it.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/label-images-sweep.sh
# A PURE trigger — zero LLM tokens. One batch is a few labels, each ~4 MusicBrainz/Discogs calls
# paced at ~1 req/s in the Worker; the vendor circuit breaker stops the pass on a throttle, so a
# tick is well under a minute. 120s is generous.
TimeoutStartSec=120
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
