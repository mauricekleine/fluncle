[Unit]
Description=fluncle-publish-advance — rave-02 host trigger for the render → publish auto-advance sweep
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/publish-advance-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service
# If this unit dies before writing its own /status marker (OOM, missing binary, a crash
# before the sweep catch runs), the healthcheck prober never sees a failure. This catch-all
# posts a minimal Discord alert; %n is this unit's full name.
OnFailure=fluncle-sweep-failure@%n.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged
# hermes user. The lone .sh is BAKED at /opt/hermes-scripts/ (Unit A — auto-updates from main
# via pin-watch); this host unit only TRIGGERS it, and the sweep self-writes its /status
# marker (cron-output.sh) so the prober stays honest.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/publish-advance-sweep.sh
# One `curl --max-time 30` POST that triggers the Worker to advance at most ONE ready
# finding into the publish push. The Worker no-ops instantly while the kill switch is on
# (which is the default), and on an empty/unready queue. The curl is wall-clock-capped at
# 30s; 240s is the ceiling on the surrounding docker-exec/shell so a tick that merely overlaps
# a pin-watch docker image build (~4 min of heavy CPU contention on this 4-vCPU box) is not
# false-killed by scheduling starvation; still far under the 30-min cadence.
TimeoutStartSec=240
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
