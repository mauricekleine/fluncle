[Unit]
Description=fluncle-label-lineage — rave-02 host trigger for the label-lineage fill sweep's bounded batch
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/label-lineage-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service
# If this unit dies before writing its own /status marker (OOM, missing binary, a crash
# before the sweep catch runs), the healthcheck prober never sees a failure. This catch-all
# posts a minimal Discord alert; %n is this unit's full name.
OnFailure=fluncle-sweep-failure@%n.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged hermes
# user. The .sh/.ts pair is BAKED at /opt/hermes-scripts/ (auto-updates from main via pin-watch);
# this host unit only TRIGGERS it, and the sweep self-writes its /status marker (cron-output.sh).
# NO new secret: `backfill_label_lineage` is AGENT tier, so the box's existing agent-scoped token
# drives it.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/label-lineage-sweep.sh
# A PURE trigger — zero LLM tokens. One batch is up to 8 labels, each ≤2 MusicBrainz lookups paced
# at ~1 req/s in the Worker; the vendor circuit breaker stops the pass on a throttle, so a tick is
# well under a minute normally. The 480s ceiling clears a window that merely overlaps a pin-watch
# docker image build (~4 min of heavy CPU contention on this 4-vCPU box) and still sits far under
# the 60-min cadence.
TimeoutStartSec=480
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
