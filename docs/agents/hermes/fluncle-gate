#!/usr/bin/env bash
# Fluncle command gate for the Hermes agent.
#
# Wraps the real CLI (`fluncle-real`). The agent's `terminal` tool calls `fluncle`,
# which is THIS script. Policy: deny-by-default within the `admin` namespace;
# public/read commands pass through. Blocked commands are publish- or
# irreversible-class and must be run by a human operator instead.
#
# To change the policy: edit this file, rebuild the image, redeploy (see
# docs/agents/hermes-agent.md). Keep the allow-list tight — when in doubt, deny.
set -euo pipefail
REAL=/usr/local/bin/fluncle-real

deny() {
  echo "BLOCKED by the fluncle command gate: this is a publish/irreversible-class command and needs a human." >&2
  echo "Do not retry it. Tell the operator exactly what you wanted to run; they will run it themselves." >&2
  echo "Policy and how to change it: docs/agents/hermes-agent.md" >&2
  exit 87
}

# Non-admin commands are public reads/submissions — always allowed.
if [ "${1:-}" != "admin" ]; then
  exec "$REAL" "$@"
fi

# admin namespace: deny-by-default, allow an explicit safe-list.
case "${2:-}" in
  ""|help|--help|-h)
    exec "$REAL" "$@" ;;
  queue|enrich-queue|enrich-sweep|vehicles)
    # Reads, plus the idempotent internal enrichment self-heal (no public effect).
    exec "$REAL" "$@" ;;
  mixtapes)
    case "${3:-}" in
      list|get) exec "$REAL" "$@" ;;
      *) deny ;;
    esac ;;
  submissions)
    case "${3:-}" in
      review) exec "$REAL" "$@" ;;
      *) deny ;;
    esac ;;
  track)
    case "${3:-}" in
      social)
        # Read status, or record an outcome a human already published. No publish.
        exec "$REAL" "$@" ;;
      draft)
        # TikTok/default is a SELF_ONLY inbox draft (safe). YouTube is a direct
        # public upload — block it.
        for tok in "$@"; do
          case "$tok" in
            youtube|--platform=youtube) deny ;;
          esac
        done
        exec "$REAL" "$@" ;;
      update)
        # Analysis write-back only. Any flag outside the analysis set (e.g.
        # --note, --video-url, --vibe-x) changes a public surface — block it.
        for tok in "$@"; do
          case "$tok" in
            --*)
              case "${tok%%=*}" in
                --status|--bpm|--key|--features|--json) ;;
                *) deny ;;
              esac ;;
          esac
        done
        exec "$REAL" "$@" ;;
      *) deny ;;
    esac ;;
  *) deny ;;
esac
