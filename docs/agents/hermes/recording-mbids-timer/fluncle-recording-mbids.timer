[Unit]
Description=fluncle-recording-mbids timer — fill one bounded batch of MusicBrainz recording MBIDs every 60m on the rave-02 host (not the Hermes gateway)

[Timer]
# First tick shortly after boot (staggered at 11min, off the other sweeps' minutes), then every
# 60m. The free PK strip drains crawler history in a few ticks; the ISRC tail is the small
# findings/Spotify-born slice (catalogue rows fill from their PK), and MusicBrainz is rate-limited
# 1 req/s (the CLI circuit-breaks on a throttle), so there is no prize for hurrying: an hourly
# cadence drains the worklist with room to spare. A tick that finds every track already
# filled/attempted is a cheap no-op.
#
# The `tracks` worklist is the durable state (`mb_recording_id` + the `mb_recording_id_attempted_at`
# stamp), so a tick missed across a reboot costs nothing — Persistent catches it up and the next
# tick resumes from the top; the attempt stamps re-skip the rows already filled/attempted.
OnBootSec=11min
OnUnitActiveSec=60min
Persistent=true

[Install]
WantedBy=timers.target
