[Unit]
Description=fluncle-observation — rave-02 host trigger for the recovered-audio observation sweep (migrated off the Hermes gateway cron runner)
Documentation=https://github.com/mauricekleine/fluncle/blob/main/docs/agents/hermes/observation-timer/README.md
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
# Root drives the Docker daemon; `docker exec -u hermes` runs the WORK as the unprivileged
# hermes user (hermes owns the 0600 secrets file the .sh sources — CLAUDE_CODE_OAUTH_TOKEN
# for the one `claude -p` authoring call). The .sh/.ts pair is BAKED at /opt/hermes-scripts/
# (Unit A — auto-updates from main via pin-watch); this host unit only TRIGGERS it, and the
# sweep self-writes its /status marker (cron-output.sh) so the prober stays honest.
ExecStart=/usr/bin/docker exec -u hermes -e HOME=/opt/data/home hermes bash /opt/hermes-scripts/observe-sweep.sh
# HYBRID: one `claude -p` authoring call + a Worker-side Cartesia voice render per finding
# (batch cap 1). Give the render leg generous headroom; still far under the old serial budget.
TimeoutStartSec=600
# Modest hardening for a root docker-driving oneshot.
NoNewPrivileges=true
ProtectControlGroups=true
ProtectKernelTunables=true
RestrictSUIDSGID=true
