{
  "name": "@fluncle/cli",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "fluncle": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target=bun",
    "build:local": "bun build ./src/cli.ts --compile --target=bun-darwin-arm64 --outfile ./dist/fluncle-darwin-arm64",
    "build:vps": "bun build ./src/cli.ts --compile --target=bun-linux-x64-baseline --outfile ./dist/fluncle",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev": "bun run ./src/cli.ts",
    "fluncle": "bun run ./src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
