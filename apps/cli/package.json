{
  "name": "@fluncle/cli",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "fluncle": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target=bun",
    "build:release": "bun run build:release:darwin-arm64 && bun run build:release:darwin-x64 && bun run build:release:linux-x64 && bun run build:release:linux-arm64",
    "build:release:darwin-arm64": "bun build ./src/cli.ts --compile --target=bun-darwin-arm64 --outfile ./dist/fluncle-darwin-arm64",
    "build:release:darwin-x64": "bun build ./src/cli.ts --compile --target=bun-darwin-x64 --outfile ./dist/fluncle-darwin-x64",
    "build:release:linux-arm64": "bun build ./src/cli.ts --compile --target=bun-linux-arm64 --outfile ./dist/fluncle-linux-arm64",
    "build:release:linux-x64": "bun build ./src/cli.ts --compile --target=bun-linux-x64 --outfile ./dist/fluncle-linux-x64",
    "build:local": "bun build ./src/cli.ts --compile --target=bun-darwin-arm64 --outfile ./dist/fluncle-darwin-arm64",
    "build:vps": "bun build ./src/cli.ts --compile --target=bun-linux-x64 --outfile ./dist/fluncle",
    "dev": "bun run ./src/cli.ts",
    "fluncle": "bun run ./src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "catalog:",
    "dotenv": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
