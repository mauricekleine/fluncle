POSTIZ_API_KEY=

TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/admin/spotify/auth/callback
SPOTIFY_PLAYLIST_ID=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
DISCORD_WEBHOOK_URL=

