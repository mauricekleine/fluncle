{
  "name": "@fluncle/web",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "bun run scripts/copy-sprites.ts && NODE_OPTIONS=--max-old-space-size=6144 vite build",
    "db:backfill": "bun run scripts/backfill-plan-recording-mixtape.ts && bun run scripts/backfill-embedding-blob.ts && bun run scripts/backfill-labels.ts && bun run scripts/backfill-albums.ts && bun run scripts/backfill-label-aliases.ts && bun run scripts/backfill-artist-links.ts && bun run scripts/backfill-artist-social-reviews.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && bun run scripts/ensure-search-index.ts",
    "db:pull-prod": "bun run scripts/db-pull-prod.ts",
    "db:refresh-dev": "bun run scripts/db-refresh.ts",
    "db:restore-drill": "bun run scripts/restore-drill.ts",
    "db:secrets": "bun run scripts/render-dev-vars.ts",
    "deploy": "bun run build && wrangler deploy",
    "deploy:cf": "bun run db:migrate && bun run db:backfill && wrangler deploy",
    "dev": "bun run scripts/dev.ts",
    "dev:vite": "bun run scripts/copy-sprites.ts && vite dev --host 127.0.0.1 --port 3000",
    "lint": "oxlint --type-aware",
    "postinstall": "fumadocs-mdx",
    "preview": "bun run build && wrangler dev",
    "pretypecheck": "fumadocs-mdx",
    "r2:cors": "wrangler r2 bucket cors set fluncle-videos --file r2-cors.json",
    "smoke:browser": "bun run smoke:shell && bun run smoke:queue && bun run smoke:touch",
    "smoke:held-note": "SEED=1 bun tests/browser/held-note-smoke.ts",
    "smoke:queue": "SEED=1 bun tests/browser/queue-smoke.ts",
    "smoke:routine": "bun run scripts/smoke-routine.ts",
    "smoke:shell": "bun tests/browser/shell-smoke.ts",
    "smoke:touch": "bun tests/browser/admin-touch-smoke.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@breezystack/lamejs": "^1.2.7",
    "@dnd-kit/core": "~6.3.1",
    "@dnd-kit/sortable": "~10.0.0",
    "@dnd-kit/utilities": "~3.2.2",
    "@fluncle/contracts": "workspace:*",
    "@fluncle/registry": "workspace:*",
    "@fluncle/sprites": "workspace:*",
    "@fluncle/tokens": "workspace:*",
    "@fluncle/ui": "workspace:*",
    "@libsql/client": "catalog:",
    "@openrouter/ai-sdk-provider": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "@scalar/api-reference-react": "~0.9.54",
    "@tailwindcss/vite": "~4.3.2",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "~1.170.17",
    "@tanstack/react-start": "~1.168.27",
    "ai": "catalog:",
    "aws4fetch": "~1.0.20",
    "better-auth": "~1.6.23",
    "class-variance-authority": "catalog:",
    "cmdk": "catalog:",
    "cnfast": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "fumadocs-core": "~16.10.7",
    "fumadocs-mdx": "~15.0.13",
    "fumadocs-ui": "~16.10.7",
    "react": "~19.2.7",
    "react-dom": "catalog:",
    "simple-icons": "~16.23.0",
    "sonner": "catalog:",
    "tailwindcss": "~4.3.1",
    "workers-og": "~0.0.27",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "~1.42.4",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "~6.0.3",
    "@vitest/coverage-v8": "~4.1.10",
    "drizzle-kit": "catalog:",
    "playwright-core": "~1.61.1",
    "shadcn": "~4.11.1",
    "typescript": "catalog:",
    "vite": "~8.1.4",
    "vitest": "~4.1.10",
    "wrangler": "~4.110.0"
  }
}
