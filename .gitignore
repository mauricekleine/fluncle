.env
.env.local
.dev.vars
# Per-worktree local dev database + snapshot (turso dev). See docs/local-database.md.
apps/web/.dev/
# Fumadocs MDX generated source index (regenerated by the vite plugin / CLI).
apps/web/.source/
.turbo/
.wrangler/
__pycache__/
node_modules/
dist/
build/
.output/
apps/*/dist/
apps/*/dist-npm/
apps/*/.output/
apps/*/.wrangler/
.DS_Store
.claude/worktrees
.claude/skills/postiz
.agents/skills/postiz/

# fluncle-ssh local dev state (host keys) and go build artifact
apps/ssh/.local/
apps/ssh/ssh

# @fluncle/video render output and downloaded audio previews (never commit)
packages/video/out/
packages/video/public/*.mp3
packages/video/public/*.m4a
packages/video/public/*.wav
# Generated/scratch track compositions (output, not codebase history); root.tsx
# auto-registers these. Keep the dir (.gitkeep) so require.context resolves.
packages/video/src/remotion/workbench/*
!packages/video/src/remotion/workbench/.gitkeep

# TanStack Start temp/cache
apps/web/.tanstack/

# Test coverage reports (vitest --coverage)
coverage/
**/coverage/

# Sprite assets mirrored into the web app's public/ by apps/web/scripts/copy-sprites.ts.
# Source of truth is the @fluncle/sprites package (packages/sprites/assets); these are
# generated copies served at stable paths. (galaxy/og.png + amen.mp3 stay tracked.)
apps/web/public/earth/
apps/web/public/galaxy/asteroid.png
apps/web/public/galaxy/earth.png
apps/web/public/galaxy/roadster.png
apps/web/public/galaxy/ship.png
apps/web/public/galaxy/ufo.png

# fluncle-sprites skill install symlinks (skills-lock.json + the package are the truth)
.claude/skills/fluncle-sprites
.agents/skills/fluncle-sprites/
