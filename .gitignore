.env
.env.local
.dev.vars
# Per-worktree local dev database + snapshot (turso dev). See docs/local-database.md.
apps/web/.dev/
# Fumadocs MDX generated source index (regenerated by the vite plugin / CLI).
apps/web/.source/
.turbo/
.wrangler/
__pycache__/
node_modules/
dist/
build/
.output/
apps/*/dist/
apps/*/dist-npm/
apps/*/.output/
apps/*/.wrangler/
.DS_Store
.claude/worktrees
.claude/skills/postiz
.agents/skills/postiz/

# fluncle-ssh local dev state (host keys) and go build artifact
apps/ssh/.local/
apps/ssh/ssh

# @fluncle/media render output — throwaway working stills (app-icon candidates,
# etc.). Committed image assets live under apps/web/public and docs/socials/banners,
# not here; anything rendered into out/ is local working state.
packages/media/out/

# @fluncle/video render output and downloaded audio previews (never commit)
packages/video/out/
packages/video/public/*.mp3
packages/video/public/*.m4a
packages/video/public/*.wav
# Real track footage for the Explainer factory beat, populated by `factory:clips`
# — a local export-time asset; the committed default renders the procedural tiles.
packages/video/public/*.mp4
# Generated/probe images dropped into public/ for local shader verification
# (textures, posters). Bitmaps are banned in renders (README "No static assets"),
# so any png here is throwaway working state, never a committed asset.
packages/video/public/*.png
packages/video/public/*.jpg
# Hash-keyed on-disk Remotion bundle cache (render.ts) — a build artifact, not
# codebase history; correctness comes from the hash gate, not from git.
packages/video/.cache/
# Generated/scratch track compositions (output, not codebase history); root.tsx
# auto-registers these. Keep the dir (.gitkeep) so require.context resolves.
packages/video/src/remotion/workbench/*
!packages/video/src/remotion/workbench/.gitkeep
# Unit O (the set-video hour render): prepped chapter compositions + the render
# workbench/output are generated, never codebase history (same contract as workbench/).
packages/video/src/remotion/set-workbench/*
!packages/video/src/remotion/set-workbench/.gitkeep
packages/video/set-out/

# TanStack Start temp/cache
apps/web/.tanstack/

# Test coverage reports (vitest --coverage)
coverage/
**/coverage/

# Sprite assets mirrored into the web app's public/ by apps/web/scripts/copy-sprites.ts.
# Source of truth is the @fluncle/sprites package (packages/sprites/assets); these are
# generated copies served at stable paths. (galaxy/og.png + amen.mp3 stay tracked.)
apps/web/public/galaxy/asteroid.png
apps/web/public/galaxy/earth.png
apps/web/public/galaxy/roadster.png
apps/web/public/galaxy/ship.png
apps/web/public/galaxy/ufo.png
apps/web/public/void/accretion.png
apps/web/public/void/discman.png
apps/web/public/void/event-horizon.png

# fluncle-sprites skill install symlinks (skills-lock.json + the package are the truth)
.claude/skills/fluncle-sprites
.agents/skills/fluncle-sprites/

# The show orchestrator's dedicated Chromium profile (runtime state, never content)
packages/live/.show-profile/

# Local, never-commit 1Password audit (item/field NAMES only, no values)
docs/1password-audit.local.md

# impeccable critique scratch (local design-review snapshots)
.impeccable/

# Nightly audit working dir (transient: report.md, verdict.json, seo-data.json).
# The DURABLE findings record is the committed docs/audit-backlog.md ledger.
.audit/

# /improve advisor session artifacts — deliberately local-only (operator ruling 2026-07-11)
/plans/
