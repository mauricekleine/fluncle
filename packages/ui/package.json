{
  "name": "@fluncle/ui",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": [
      "./src/hooks/*.ts",
      "./src/hooks/*.tsx"
    ],
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": [
      "./src/hooks/*.ts",
      "./src/hooks/*.tsx"
    ],
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@fluncle/tokens": "workspace:*",
    "@phosphor-icons/react": "catalog:",
    "class-variance-authority": "catalog:",
    "cmdk": "catalog:",
    "cnfast": "catalog:",
    "sonner": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "shadcn": "~4.11.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "~19.2.7",
    "react-dom": "catalog:"
  }
}
