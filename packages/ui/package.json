{
  "name": "@fluncle/ui",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": [
      "./src/hooks/*.ts",
      "./src/hooks/*.tsx"
    ],
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": [
      "./src/hooks/*.ts",
      "./src/hooks/*.tsx"
    ],
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "~1.6.0",
    "@fluncle/tokens": "workspace:*",
    "@phosphor-icons/react": "~2.1.10",
    "class-variance-authority": "~0.7.1",
    "cmdk": "~1.1.1",
    "cnfast": "~0.0.8",
    "shadcn": "~4.11.0",
    "sonner": "~2.0.7"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "~19.2.7",
    "react-dom": "~19.2.7"
  }
}
